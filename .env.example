# Уровни логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
SCHPY_LOG_LEVEL=INFO
SCHPY_DB_LOG_LEVEL=INFO
SCHPY_WINDOW_LOG_LEVEL=INFO
SCHPY_SCHEDULE_MAKER_LOG_LEVEL=INFO
SCHPY_BEST_OF_LOG_LEVEL=INFO
SCHPY_MAIN_LOG_LEVEL=INFO

# Отладка и производительность
SCHPY_DEBUG=false
SCHPY_PERFORMANCE_LOGS=false
SCHPY_SCHEDULE_LOGS=false

# Дополнительные настройки (при необходимости)
# LOGS_DIR=./logs
# LOG_MAX_SIZE=10485760  # 10MB в байтах